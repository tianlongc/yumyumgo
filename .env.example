# YumYumGo - Environment Variables Example
# Duplicate this file to .env and fill in your keys.
# These keys are securely consumed by Vercel Serverless Functions in the /api directory

GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
WEATHER_API_KEY=your_openweather_api_key_here
